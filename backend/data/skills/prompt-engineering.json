{
  "id": "prompt-engineering",
  "name": "Prompt Engineering",
  "type": "skill",
  "overview": "Prompt Engineering is the art and science of communicating effectively with Large Language Models (LLMs). It involves crafting, optimizing, and refining inputs to achieve high-quality, reliable, and predictable AI outputs.",
  "prerequisites": [
    "Basic computer literacy",
    "Curiosity about AI behavior",
    "Good communication skills"
  ],
  "concepts": [
    "Zero-shot vs Few-shot Prompting",
    "Chain-of-Thought (CoT)",
    "System vs User Prompts",
    "Temperature & Top-P Sampling",
    "Hallucination Mitigation",
    "Prompt Injection & Security"
  ],
  "learningOrder": [
    "LLM Foundations",
    "Basic Prompting Frameworks",
    "Advanced Reasoning Techniques",
    "Agentic Programmatic Prompting"
  ],
  "tools": [
    "OpenAI Playground",
    "Anthropic Console",
    "LangChain",
    "Promptfoo",
    "BetterPrompt"
  ],
  "roadmap": {
    "beginner": [
      "Understanding LLM Architecture basics",
      "Drafting clear, explicit instructions",
      "Using Delimiters and structured output formats",
      "Basic creative writing with AI"
    ],
    "intermediate": [
      "Role-based prompting techniques",
      "Few-shot examples for style transfer",
      "Negative constraints and avoidance",
      "Introduction to RAG (Retrieval Augmented Generation)"
    ],
    "advanced": [
      "Chain-of-Thought and Least-to-Most prompting",
      "ReAct patterns (Reasoning + Acting)",
      "Programmatic prompting with JSON schema",
      "Red-teaming and prompt security"
    ]
  },
